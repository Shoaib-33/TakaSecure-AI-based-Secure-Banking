# vLLM OpenAI-compatible server
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=local-vllm
VLLM_MODEL=takasecure

# Corpus and retrieval
POLICY_PDF=data/rag/v4/TakaSecure_Enterprise_Banking_Policy_Corpus_v4.pdf
CORPUS_VERSION=4.0
QDRANT_LOCATION=:memory:
QDRANT_COLLECTION=takasecure_policy_v4
DENSE_EMBEDDING_MODEL=BAAI/bge-m3
SPARSE_EMBEDDING_MODEL=Qdrant/bm25
RERANKER_MODEL=BAAI/bge-reranker-base
RETRIEVAL_K=20
RERANK_TOP_N=8

# Verified-answer cache. Leave blank to run without the cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_TTL_SECONDS=86400
CACHE_NAMESPACE=takasecure:v1

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=takasecure-adaptive-rag
